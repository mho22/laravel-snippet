{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build:worker": "node scripts/build-worker.ts",
        "build:bundle": "node scripts/build-bundle.ts",
        "sync:assets": "node scripts/sync-assets.ts",
        "sync:docs": "node scripts/sync-docs.ts",
        "build": "npm run sync:assets && npm run build:bundle && npm run build:worker && vite build",
        "dev": "npm run sync:assets && npm run build:bundle && npm run build:worker && vite",
        "prerender": "node scripts/prerender.ts",
        "test:snippets": "playwright test; node tests/browser/build-report.ts"
    },
    "devDependencies": {
        "@playwright/test": "^1.49.0",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "concurrently": "^9.0.1",
        "esbuild": "^0.28.0",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.0",
        "vue-tsc": "^3.3.3"
    },
    "dependencies": {
        "@inertiajs/vue3": "^3.3.0",
        "@php-wasm/web": "^3.1.36",
        "vue": "^3.5.35"
    }
}
